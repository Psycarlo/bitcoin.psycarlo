---
import Layout from '../layouts/layout.astro';
---

<Layout>
	<div class="h-full bg-[#1a1a1a] text-white font-sans">
		<main class="h-full flex justify-center items-center">
			<div id="content" class="flex items-center flex-col w-full max-w-120 p-4 transition-transform duration-500 ease-in-out">
				<h1 class="text-[28px] m-0 mb-6 text-white">bitcoin-decoder</h1>
				<div class="flex w-full">
					<input
						type="text"
						id="bitcoin-input"
						class="flex-1 px-4 py-3 bg-transparent border border-[#555] rounded-none text-white text-base outline-none placeholder-[#777] focus:border-[#888]"
						placeholder="Enter bitcoin URI, invoice, address, ..."
					/>
					<button id="decode-btn" type="button" class="px-5 py-3 bg-white text-[#1a1a1a] border-none rounded-none text-base cursor-pointer whitespace-nowrap hover:bg-[#e0e0e0]">Decode</button>
				</div>
				<div id="result" class="w-full mt-6 transition-opacity duration-400 ease-in-out opacity-0"></div>
			</div>
		</main>
	</div>
</Layout>

<script>
	import { decode } from 'bitcoin-decoder';

	const input = document.querySelector('#bitcoin-input') as HTMLInputElement;
	const btn = document.querySelector('#decode-btn') as HTMLButtonElement;
	const result = document.querySelector('#result') as HTMLDivElement;
	const content = document.querySelector('#content') as HTMLDivElement;

	const row = (label: string, text: string, extra = '') =>
		`<div class="flex justify-between py-2.5 border-b border-[#333]"><span class="text-[#777] text-sm">${label}</span><span class="text-white text-sm text-right ${extra}">${text}</span></div>`;

	const handleDecode = async () => {
		const inputValue = input.value.trim();
		if (!inputValue) {return;}

		const decoded = await decode(inputValue);
		input.value = '';

		content.classList.add('-translate-y-20');

		if (decoded.valid) {
			let html = '';

			if (decoded.metadata?.amount !== undefined && decoded.metadata.amount !== null) {
				html += row('Amount', `${decoded.metadata.amount} sats`);
			}

			if (decoded.metadata?.description) {
				html += row('Description', decoded.metadata.description);
			}

			html += row('Network', decoded.network);

			for (const [, dest] of decoded.destinations.entries()) {
				const isPrimary = dest === decoded.destination;
				const sectionLabel = decoded.destinations.length > 1
					? `${dest.protocol}${isPrimary ? ' ★' : ''}`
					: dest.protocol;

				html += `<div class="mt-4 mb-1"><span class="text-[#777] text-xs uppercase tracking-wide">${sectionLabel}</span></div>`;
				html += row('Type', dest.type);
				html += row('Destination', dest.destination, 'max-w-[280px] break-all');

				if ('addressType' in dest) {
					html += row('Address Type', dest.addressType);
				}
			}

			result.innerHTML = html;
		} else {
			result.innerHTML = `<div class="text-[#ff6b6b] text-sm text-center py-2.5">${decoded.errorMessage}</div>`;
		}

		result.classList.remove('opacity-0');
		result.classList.add('opacity-100');
	};

	btn.addEventListener('click', handleDecode);
	input.addEventListener('keydown', (e) => {
		if (e.key === 'Enter') {handleDecode();}
	});
</script>
