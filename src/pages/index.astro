---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div id="container">
		<main>
			<section id="hero">
				<h1>Bitcoin</h1>
				<input
					type="text"
					id="bitcoin-input"
					placeholder="Enter bitcoin URI, invoice, address, ..."
				/>
			</section>
		</main>
	</div>
</Layout>

<style>
	#container {
		font-family: Inter, Roboto, 'Helvetica Neue', 'Arial Nova', 'Nimbus Sans', Arial, sans-serif;
		height: 100%;
		background: #1a1a1a;
		color: #ffffff;
	}

	main {
		height: 100%;
		display: flex;
		justify-content: center;
	}

	#hero {
		display: flex;
		align-items: center;
		flex-direction: column;
		justify-content: center;
		padding: 16px;
		width: 100%;
		max-width: 480px;
	}

	h1 {
		font-size: 28px;
		margin: 0 0 24px;
		color: #ffffff;
	}

	#bitcoin-input {
		width: 100%;
		padding: 12px 16px;
		background: transparent;
		border: 1px solid #555;
		border-radius: 0;
		color: #ffffff;
		font-size: 16px;
		outline: none;
		box-sizing: border-box;
	}

	#bitcoin-input::placeholder {
		color: #777;
	}

	#bitcoin-input:focus {
		border-color: #888;
	}
</style>
